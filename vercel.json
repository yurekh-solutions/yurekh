{
  "rewrites": [
    { "source": "/ainos/:path*", "destination": "https://ainos-jsd7mrxq3-yurekhs-projects.vercel.app/ainos/:path*" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
